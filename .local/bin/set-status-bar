#!/bin/sh

fsmon() {
	ROOTPART=$(df -h | awk '/\/$/ { print $4 }') 
	echo "ΎΓι $ROOTPART"
}

ram() {
	mem=$(free -h | awk '/Mem:/ { print $3 }' | cut -f1 -d 'i')
	echo "Ό┐Ζ $mem"
}

cpu() {
	read -r cpu a b c previdle rest < /proc/stat
	prevtotal=$((a+b+c+previdle))
	sleep 0.01
	read -r cpu a b c idle rest < /proc/stat
	total=$((a+b+c+idle))
	cpu=$((100*( (total-prevtotal) - (idle-previdle) ) / (total-prevtotal) ))
	echo "ΎΜδ $cpu%"
}

network() {
	route=$(ip route | awk '/default/' | head -n 1)
	if [ -z "$route" ]; then
		echo "≤▒αΨ down"
  else
    interface=$(echo "$route" | cut -d ' ' -f 5)
    conntype=$(echo "$interface" | awk '{ print substr($1,1,1) }')
    ip=$(echo "$route" | cut -d ' ' -f 9)
    if [ "$conntype" = "e" ]; then
      echo "≤░ΙΑ up via $interface ($ip)"
    else
      echo "≤░Ψσ up ($ip)"
    fi
	fi
}

volume_pa() {
	muted=$(pactl list sinks | awk '/Mute:/ { print $2 }')
	vol=$(pactl list sinks | grep Volume: | awk 'FNR == 1 { print $5 }' | cut -f1 -d '%')

	if [ "$muted" = "yes" ]; then
		echo "Ό╗ρ muted"
	else
		if [ "$vol" -ge 65 ]; then
			echo "ΎΑρ $vol%"
		elif [ "$vol" -ge 40 ]; then
			echo "ΎΑπ $vol%"
		elif [ "$vol" -ge 0 ]; then
			echo "ΎΑο $vol%"	
		fi
	fi

}

volume_alsa() {

	mono=$(amixer -M sget Master | grep Mono: | awk '{ print $2 }')

	if [ -z "$mono" ]; then
		muted=$(amixer -M sget Master | awk 'FNR == 6 { print $7 }' | sed 's/[][]//g')
		vol=$(amixer -M sget Master | awk 'FNR == 6 { print $5 }' | sed 's/[][]//g; s/%//g')
	else
		muted=$(amixer -M sget Master | awk 'FNR == 5 { print $6 }' | sed 's/[][]//g')
		vol=$(amixer -M sget Master | awk 'FNR == 5 { print $4 }' | sed 's/[][]//g; s/%//g')
	fi

	if [ "$muted" = "off" ]; then
		echo "Ύγσ muted"
	else
		if [ "$vol" -ge 65 ]; then
			echo "ΎΑρ $vol%"
		elif [ "$vol" -ge 40 ]; then
			echo "ΎΑπ $vol%"
		elif [ "$vol" -ge 0 ]; then
			echo "ΎΑο $vol%"	
		fi
	fi
}

clock() {
	date=$(date +"%D")
	time=$(date +"%H:%M")

	echo "ΎΒ│ $date ΎΑΩ $time"
}

battery() {
	bat="$(ls /sys/class/power_supply | grep BAT)"
	if [ "$bat" ]; then
		capacity="$(cat "/sys/class/power_supply/$bat/capacity")"
		status="$(cat "/sys/class/power_supply/$bat/status")"

		if [ $capacity -lt 10 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░λε; else echo ≤░Β║; fi)
		elif [ $capacity -lt 20 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░ΓΗ; else echo ≤░Β╗; fi)
		elif [ $capacity -lt 30 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░ΓΘ; else echo ≤░Β╝; fi)
		elif [ $capacity -lt 40 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░ΓΙ; else echo ≤░Β╜; fi)
		elif [ $capacity -lt 50 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░λζ; else echo ≤░Β╛; fi)
		elif [ $capacity -lt 60 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░ΓΚ; else echo ≤░Β┐; fi)
		elif [ $capacity -lt 70 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░λη; else echo ≤░ΓΑ; fi)
		elif [ $capacity -lt 80 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░ΓΛ; else echo ≤░ΓΒ; fi)
		elif [ $capacity -lt 90 ]; then
			icon=$(if [ $status = "Charging" ]; then echo ≤░ΓΜ; else echo ≤░ΓΓ; fi)
		else
			icon=$(if [ $status = "Charging" ]; then echo ≤░ΓΖ; else echo ≤░Β╣; fi)
		fi

		echo "$icon $capacity%"

	else
		echo "≤▒Κζ No battery"
	fi
}

xsetroot -name "| $(battery) | $(fsmon) | $(ram) | $(cpu) | $(network) | $(volume_alsa) | $(clock)"
